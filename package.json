{
  "name": "root",
  "private": true,
  "keywords": [],
  "author": "",
  "type": "module",
  "scripts": {
    "package:dev": "pnpm --filter astro-asset-map dev",
    "playground:dev": "pnpm --filter playground dev",
    "dev": "pnpm --stream -r -parallel dev",
    "build": "pnpm --filter astro-asset-map build",
    "typecheck": "pnpm --filter astro-asset-map typecheck",
    "test": "pnpm --filter astro-asset-map test:run",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "ci:publish": "pnpm publish -r",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.10.0"
}
