{
  "name": "astro-asset-map",
  "version": "0.0.1",
  "description": "Type-safe asset lookup for Astro.",
  "keywords": [
    "astro",
    "astro-asset",
    "astro-asset-map",
    "astro-integration",
    "withastro"
  ],
  "homepage": "https://github.com/vfshera/astro-asset-map#readme",
  "bugs": "https://github.com/vfshera/astro-asset-map/issues",
  "license": "MIT",
  "author": {
    "name": "Franklin Shera",
    "url": "https://github.com/vfshera"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vfshera/astro-asset-map.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "prepublishOnly": "pnpm build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "typecheck": "astro check"
  },
  "dependencies": {
    "fastest-levenshtein": "^1.0.16",
    "pathe": "^2.0.3",
    "tinyglobby": "^0.2.17"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@astrojs/check": "^0.9.9",
    "@arethetypeswrong/core": "^0.18.4",
    "@types/node": "^26.1.1",
    "astro": "^7.0.7",
    "publint": "^0.3.21",
    "tsdown": "^0.22.4",
    "vite": "^8.0.13",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "astro": "^6.0.0 || ^7.0.0"
  }
}
